<Window x:Class="GardensRu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AutoParts — вход в систему"
        Height="584"
        Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFEAF6FB">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#5BA8C2"/>
        <SolidColorBrush x:Key="PrimaryBrushHover" Color="#4A97B1"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D7EDF6"/>
        <SolidColorBrush x:Key="CardBrush" Color="#F8FCFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1B4C63"/>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12 8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#335BA8C2"
                                      BlurRadius="12"
                                      ShadowDepth="0"
                                      Opacity="0.25"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryBrushHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10 8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10 8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="337*"/>
            <RowDefinition Height="85*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                Padding="20"
                CornerRadius="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="48" Height="48" Background="#33FFFFFF" CornerRadius="0">
                        <TextBlock Text="🚘" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Автозапчасти и аксессуары" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Авторизуйтесь, чтобы управлять магазином автотоваров" Foreground="#E3F6FD" FontSize="15"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="30,30,30,30" Grid.RowSpan="2">
            <Border Background="{StaticResource CardBrush}"
                    CornerRadius="0"
                    Padding="30"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1.5">
                <StackPanel>
                    <TextBlock Text="Вход в систему"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Введите учетные данные сотрудника AutoParts"
                               FontWeight="Normal"
                               Foreground="#547484"/>

                    <StackPanel Margin="0,24,0,0">
                        <TextBlock Text="Логин"/>
                        <TextBox x:Name="LoginTextBox"/>
                    </StackPanel>

                    <StackPanel Margin="0,18,0,0">
                        <TextBlock Text="Пароль"/>
                        <Grid>
                            <PasswordBox x:Name="PasswordBox" PasswordChar="•"/>
                            <TextBox x:Name="VisiblePasswordBox"
                                     Visibility="Collapsed"/>
                        </Grid>
                    </StackPanel>

                    <CheckBox x:Name="ShowPasswordCheckBox"
                              Content="Показать пароль"
                              Checked="ShowPasswordCheckBox_Checked"
                              Unchecked="ShowPasswordCheckBox_Unchecked"/>

                    <Button x:Name="LoginButton"
                            Content="Войти"
                            Margin="0,24,0,0"
                            Height="44"
                            Click="LoginButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
