<Window x:Class="GardensRu.Panel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Панель управления"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        MinHeight="720"
        MinWidth="1420"
        Background="#FFEAF6FB">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#5BA8C2"/>
        <SolidColorBrush x:Key="PrimaryBrushHover" Color="#4A97B1"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#A7D8E8"/>
        <SolidColorBrush x:Key="NavBackgroundBrush" Color="#D7EDF6"/>
        <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#F8FCFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1B4C63"/>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14 10"/>
            <Setter Property="Margin" Value="0 8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#335BA8C2"
                                      BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.25"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryBrushHover}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12 14"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Effect" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="Transparent"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#335BA8C2"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="Border" Property="Background" Value="White"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Top header -->
        <Border Grid.Row="0"
                Background="{StaticResource PrimaryBrush}"
                Padding="20"
                CornerRadius="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="Магазин Автозапчастей и аксессуаров" Foreground="White" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Единая панель управления магазином автотоваров" Foreground="#E3F6FD" FontSize="16"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,24,0">
                        <TextBlock Text="{Binding CurrentUserFullName, FallbackValue=Пользователь}" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CurrentUserRoleName, FallbackValue=Роль}" Foreground="#E3F6FD" FontSize="16"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,24,0">
                        <TextBlock Text="Текущее время" Foreground="#E3F6FD" FontSize="14"/>
                        <TextBlock Text="{Binding CurrentDateTime}" Foreground="White" FontSize="16"/>
                    </StackPanel>
                    <Button Content="Выйти"
                            Click="LogoutButton_Click"
                            Width="120"
                            Padding="10"
                            Background="#FF457D95"
                            Foreground="White"
                            Margin="0"
                            Effect="{x:Null}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main layout -->
        <Grid Grid.Row="1" Margin="20,10,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Navigation -->
            <Border Background="{StaticResource NavBackgroundBrush}"
                    CornerRadius="0"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Навигация" FontSize="20" Margin="0,0,0,16"/>
                    <Button x:Name="InventoryButton"
                            Content="Ассортимент"
                            Click="InventoryButton_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="StockButton"
                            Content="Склад"
                            Click="StockButton_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="OrdersButton"
                            Content="Заказы клиентов"
                            Click="OrdersButton_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="PurchasesButton"
                            Content="Закупки и поставщики"
                            Click="PurchasesButton_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="ReportsButton"
                            Content="Отчетность"
                            Click="ReportsButton_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="UsersButton"
                            Content="Пользователи и роли"
                            Click="UsersButton_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Column="1"
                    Margin="20,0,0,0"
                    Background="{StaticResource ContentBackgroundBrush}"
                    CornerRadius="0"
                    Padding="24"
                    x:Name="ContentHostBorder">
                <ContentControl x:Name="ContentPresenter" Margin="0,0,-24,0"/>
            </Border>
        </Grid>
    </Grid>
</Window>