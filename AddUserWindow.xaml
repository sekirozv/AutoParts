<Window x:Class="GardensRu.AddUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление пользователя" 
        Height="450" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFEAF6FB">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добавление нового пользователя" 
           FontSize="20" FontWeight="Bold" Margin="0,0,0,10"
           HorizontalAlignment="Center" Foreground="#5BA8C2"/>

        <TextBlock Grid.Row="1" Text="Логин:" Margin="5"/>
        <TextBox x:Name="UsernameTextBox" Grid.Row="1" Margin="5,25,5,5"/>

        <TextBlock Grid.Row="2" Text="Пароль:" Margin="5"/>
        <PasswordBox x:Name="PasswordBox" Grid.Row="2" Margin="5,25,5,5"/>

        <TextBlock Grid.Row="3" Text="Полное имя:" Margin="5"/>
        <TextBox x:Name="FullNameBox" Grid.Row="3" Margin="5,25,5,5"/>

        <TextBlock Grid.Row="4" Text="Email:" Margin="5"/>
        <TextBox x:Name="EmailTextBox" Grid.Row="4" Margin="5,25,5,5"/>

        <TextBlock Grid.Row="5" Text="Телефон:" Margin="5"/>
        <TextBox x:Name="PhoneTextBox" Grid.Row="5" Margin="5,25,5,5"/>

        <TextBlock Grid.Row="6" Text="Роль:" Margin="5"/>
        <ComboBox x:Name="RoleComboBox" Grid.Row="6" Margin="5,25,5,5"/>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Отмена" Width="80" Margin="5" 
                    Background="#FFE57373" BorderBrush="#FFEF5350" Click="CancelButton_Click"/>
            <Button x:Name="SaveButton" Content="Сохранить" Width="80" Margin="5" 
                    Background="#FF81C784" BorderBrush="#FF66BB6A" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>