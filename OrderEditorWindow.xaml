<Window x:Class="GardensRu.OrderEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Новый заказ"
        Height="660"
        Width="1320"
        WindowStartupLocation="CenterOwner"
        Background="#F5FAFD"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#5BA8C2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D7EDF6"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1B4C63"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="RowBackground" Value="#F7FBFD"/>
            <Setter Property="AlternatingRowBackground" Value="#E9F5FA"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Создание заказа" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Выберите клиента, добавьте необходимые позиции и сохраните заказ."
                       Opacity="0.75"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="296*"/>
                <ColumnDefinition Width="41*"/>
                <ColumnDefinition Width="303*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="16"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,12">
                        <TextBox x:Name="ProductSearchTextBox"
                                 Width="220"
                                 TextChanged="ProductSearchTextBox_TextChanged"
                                 ToolTip="Поиск по названию или артикулу"/>
                        <Button Content="Сбросить"
                                Width="110"
                                Click="ResetProductFilterButton_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="ProductsDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="110"/>
                            <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="200"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N2} ₽}" Width="100"/>
                            <DataGridTextColumn Header="Остаток" Binding="{Binding StockQuantity}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="16"
                    Margin="12,0,0,0" Grid.ColumnSpan="2">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,12">
                        <Button Content="Добавить позицию"
                                Width="150"
                                Click="AddProductButton_Click"/>
                        <TextBlock x:Name="CartInfoTextBlock"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Opacity="0.7"/>
                    </StackPanel>

                    <DataGrid x:Name="CartDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="200" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Кол-во" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                 PreviewTextInput="QuantityTextBox_PreviewTextInput"
                                                 HorizontalContentAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat={}{0:N2} ₽}" Width="110" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding LineTotal, StringFormat={}{0:N2} ₽}" Width="130" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Действия" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Удалить"
                                                Width="70"
                                                Click="RemoveProductButton_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,12,0,0">
                        <TextBlock x:Name="OrderTotalTextBlock"
                                   Text="Итого: 0 ₽"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="1"
                CornerRadius="0"
                Padding="16"
                Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Клиент:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox x:Name="CustomerComboBox"
                              Width="260"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"/>
                    <Button Content="Новый клиент"
                            Width="140"
                            Margin="12,0,0,0"
                            Click="AddCustomerButton_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить заказ" Width="160" Click="SaveOrderButton_Click"/>
                    <Button Content="Отмена" Width="120" Click="CancelButton_Click" Background="#A9B7BF"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>


