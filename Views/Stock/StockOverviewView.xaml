<UserControl x:Class="GardensRu.Views.Stock.StockOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#5BA8C2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D7EDF6"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFF1C0"/>
        <SolidColorBrush x:Key="CriticalBrush" Color="#FFE3B2"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1B4C63"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A97B1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#A9B7BF"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="RowBackground" Value="#F7FBFD"/>
            <Setter Property="AlternatingRowBackground" Value="#E9F5FA"/>
        </Style>

        <Style x:Key="StockRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding StockQuantity}" Value="0">
                    <Setter Property="Background" Value="{StaticResource CriticalBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                    <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Управление складом"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Контролируйте остатки, фиксируйте движения товаров и формируйте заявки поставщикам."
                       Opacity="0.8"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="433"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="16" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBox Width="220"
                                 x:Name="StockSearchTextBox"
                                 TextChanged="StockSearchTextBox_TextChanged"
                                 ToolTip="Поиск по названию или артикулу"/>
                        <Button Content="Сбросить"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ResetFiltersButton_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="ProductsDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="ProductsDataGrid_SelectionChanged"
                              RowStyle="{StaticResource StockRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="1*"/>
                            <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="2*"/>
                            <DataGridTextColumn Header="Остаток" Binding="{Binding StockQuantity}" Width="0.8*"/>
                            <DataGridTextColumn Header="Мин. остаток" Binding="{Binding MinStockLevel}" Width="0.8*"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding StockStatus}" Width="1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="16" HorizontalAlignment="Center" Width="414">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Vertical" Margin="0,0,0,12">
                        <TextBlock Text="Движение товара"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="SelectedProductInfoTextBlock"
                                   Text="Выберите товар из списка слева"
                                   Opacity="0.7"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <DataGrid x:Name="StockMovementsDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              AlternatingRowBackground="#F0F6FA"
                              Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding MovementDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="1.6*"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding MovementType}" Width="0.8*"/>
                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="0.8*"/>
                            <DataGridTextColumn Header="Основание" Binding="{Binding Reference}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Приход"
                                    Width="100"
                                    Click="RegisterArrivalButton_Click"/>
                            <Button Content="Расход"
                                    Width="100"
                                    Click="RegisterConsumptionButton_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Мин. остаток"
                                    Width="130"
                                    Click="SetMinStockButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                            <Button Content="Сформировать заявку"
                                    Width="170"
                                    Click="CreatePurchaseOrderButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Обновить" Click="RefreshButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>

