<UserControl x:Class="GardensRu.Views.Users.UsersManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#5BA8C2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D7EDF6"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#EF5350"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1B4C63"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="RowBackground" Value="#F7FBFD"/>
            <Setter Property="AlternatingRowBackground" Value="#E9F5FA"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Управление пользователями"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Добавляйте, редактируйте и удаляйте учетные записи сотрудников и клиентов."
                       Opacity="0.8"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="1"
                CornerRadius="0"
                Padding="16">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="UsersDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Margin="0,0,0,12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="160"/>
                        <DataGridTextColumn Header="Полное имя" Binding="{Binding FullName}" Width="160"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="160"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="140"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="140"/>
                        <DataGridTemplateColumn Header="Действия" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Пароль" Width="75" Click="ChangePasswordButton_Click"/>
                                        <Button Content="Удалить"
                                                Width="75"
                                                Margin="6,0,0,0"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Click="DeleteUserButton_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Обновить" Width="120" Click="RefreshButton_Click"/>
                    <Button Content="Добавить пользователя" Width="190" Click="AddUserButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

