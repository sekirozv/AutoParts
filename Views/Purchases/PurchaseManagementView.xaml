<UserControl x:Class="GardensRu.Views.Purchases.PurchaseManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#5BA8C2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D7EDF6"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1B4C63"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="RowBackground" Value="#F7FBFD"/>
            <Setter Property="AlternatingRowBackground" Value="#E9F5FA"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Управление закупками"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Отслеживайте заказы поставщикам и фиксируйте поступления на склад."
                       Opacity="0.8"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="605"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="PurchaseOrdersDataGrid"
                              Grid.Row="0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="PurchaseOrdersDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding PurchaseOrderID}" Width="80"/>
                            <DataGridTextColumn Header="Поставщик" Binding="{Binding SupplierName}" Width="200"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:N2} ₽}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Обновить" Width="120" Click="RefreshButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="16" Margin="10,0,0,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Состав закупки" FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="PurchaseSummaryTextBlock"
                                   Text="Выберите заказ поставщику"
                                   Opacity="0.7"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <DataGrid x:Name="PurchaseDetailsDataGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="300"/>
                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="65"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat={}{0:N2} ₽}" Width="85"/>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding LineTotal, StringFormat={}{0:N2} ₽}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Статус: в пути"
                                    Width="150"
                                    Click="MarkInTransitButton_Click"/>
                            <Button Content="Статус: получен"
                                    Width="189"
                                    Margin="2,0,0,0"
                                    Click="MarkReceivedButton_Click"/>
                        </StackPanel>
                        <Button Content="Отменить заказ"
                                Width="150"
                                Click="CancelOrderButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

