<UserControl x:Class="GardensRu.Views.Orders.OrdersManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#5BA8C2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D7EDF6"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1B4C63"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="RowBackground" Value="#F7FBFD"/>
            <Setter Property="AlternatingRowBackground" Value="#E9F5FA"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Управление заказами"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Оформляйте заказы клиентов, отслеживайте статусы и печатайте документы."
                       Opacity="0.8"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="16"
                    Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="OrderSearchTextBox"
                             Width="200"
                             TextChanged="OrderSearchTextBox_TextChanged"
                             ToolTip="Поиск по клиенту или номеру заказа"/>
                    <ComboBox x:Name="StatusFilterComboBox"
                              Width="180"
                              Margin="12,0,0,0"
                              SelectionChanged="StatusFilterComboBox_SelectionChanged">
                        <ComboBoxItem Content="Все статусы" Tag="All" IsSelected="True"/>
                        <ComboBoxItem Content="Новый" Tag="Новый"/>
                        <ComboBoxItem Content="В обработке" Tag="В обработке"/>
                        <ComboBoxItem Content="Выполнен" Tag="Выполнен"/>
                        <ComboBoxItem Content="Отменен" Tag="Отменен"/>
                    </ComboBox>
                    <DatePicker x:Name="StartDatePicker"
                                Width="150"
                                Margin="12,0,0,0"
                                SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                    <DatePicker x:Name="EndDatePicker"
                                Width="150"
                                Margin="12,0,0,0"
                                SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                    <Button Content="Сбросить"
                            Margin="12,0,0,0"
                            Click="ResetFiltersButton_Click"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="683"/>
                </Grid.ColumnDefinitions>

                <Border Background="White"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="0"
                        Padding="16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="OrdersDataGrid"
                                  Grid.Row="0"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionChanged="OrdersDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="№" Binding="{Binding OrderID}" Width="0.5*"/>
                                <DataGridTextColumn Header="Дата" Binding="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}" Width="1*"/>
                                <DataGridTextColumn Header="Клиент" Binding="{Binding CustomerName}" Width="2*"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="1*"/>
                                <DataGridTextColumn Header="Итого" Binding="{Binding TotalAmount, StringFormat={}{0:N2} ₽}" Width="1*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button Content="Создать заказ" Click="CreateOrderButton_Click"/>
                            <Button Content="Обновить" Click="RefreshButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="White"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="0"
                        Padding="16" Margin="10,0,0,0">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Детали заказа"
                                       FontSize="18"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="OrderSummaryTextBlock"
                                       Text="Выберите заказ для просмотра подробностей."
                                       Opacity="0.7"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <DataGrid x:Name="OrderDetailsDataGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="2*"/>
                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="0.5*"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat={}{0:N2} ₽}" Width="1*"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding LineTotal, StringFormat={}{0:N2} ₽}" Width="1*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ComboBox x:Name="StatusUpdateComboBox"
                                          Width="160">
                                    <ComboBoxItem Content="Новый"/>
                                    <ComboBoxItem Content="В обработке"/>
                                    <ComboBoxItem Content="Выполнен"/>
                                    <ComboBoxItem Content="Отменен"/>
                                </ComboBox>
                                <Button Content="Изменить статус"
                                        Width="124"
                                        Margin="12,0,0,0"
                                        Click="UpdateStatusButton_Click"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Печать счета"
                                        Width="140"
                                        Click="PrintInvoiceButton_Click"/>
                                <Button Content="Печать накладной"
                                        Width="160"
                                        Click="PrintSlipButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

