<UserControl x:Class="GardensRu.Views.Inventory.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="950">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#5BA8C2"/>
        <SolidColorBrush x:Key="AccentLightBrush" Color="#D7EDF6"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1B4C63"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="Margin" Value="0 0 10 0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A97B1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="8 6"/>
            <Setter Property="Margin" Value="0 0 12 0"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0 0 12 0"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentLightBrush}"/>
            <Setter Property="RowBackground" Value="#F7FBFD"/>
            <Setter Property="AlternatingRowBackground" Value="#E9F5FA"/>
            <Setter Property="VerticalGridLinesBrush" Value="#B7D5E1"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#B7D5E1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,16">
            <TextBlock Text="Управление ассортиментом"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Добавляйте и редактируйте автозапчасти, аксессуары и расходные материалы."
                       Foreground="{StaticResource TextBrush}"
                       Opacity="0.8"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
            <TextBox x:Name="SearchTextBox"
                     Width="220"
                     ToolTip="Поиск по названию или артикулу"
                     TextChanged="SearchTextBox_TextChanged"/>
            <ComboBox x:Name="CategoryFilterComboBox"
                      Width="180"
                      Margin="0,0,12,0"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      SelectionChanged="CategoryFilterComboBox_SelectionChanged"/>
            <ComboBox x:Name="BrandFilterComboBox"
                      Width="180"
                      Margin="0,0,12,0"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      SelectionChanged="BrandFilterComboBox_SelectionChanged"/>
            <ComboBox x:Name="AvailabilityComboBox"
                      Width="180"
                      SelectionChanged="AvailabilityComboBox_SelectionChanged">
                <ComboBoxItem Content="Все товары" Tag="All" IsSelected="True"/>
                <ComboBoxItem Content="В наличии" Tag="InStock"/>
                <ComboBoxItem Content="Заканчиваются" Tag="LowStock"/>
                <ComboBoxItem Content="Нет на складе" Tag="OutOfStock"/>
            </ComboBox>
            <Button Content="Сбросить фильтры" Click="ResetFiltersButton_Click"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="ProductsDataGrid"
                      Grid.Row="0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Margin="0,0,0,12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="1*"/>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="2*"/>
                    <DataGridTextColumn Header="Бренд" Binding="{Binding BrandName}" Width="1*"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="1*"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat={}{0:N2} ₽}" Width="1*"/>
                    <DataGridTextColumn Header="Остаток" Binding="{Binding StockQuantity}" Width="0.8*"/>
                    <DataGridTextColumn Header="Мин. остаток" Binding="{Binding MinStockLevel}" Width="0.8*"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Добавить товар" Click="AddProductButton_Click"/>
                <Button Content="Изменить" Click="EditProductButton_Click"/>
                <Button Content="Удалить" Click="DeleteProductButton_Click" Background="#FFB76868"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

