<UserControl x:Class="GardensRu.Views.Reports.ReportsOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#5BA8C2"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D7EDF6"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1B4C63"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10 6"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="RowBackground" Value="#F7FBFD"/>
            <Setter Property="AlternatingRowBackground" Value="#E9F5FA"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Отчетность"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Стандартные отчеты по продажам, остаткам и популярности автотоваров."
                       Opacity="0.8"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="1"
                CornerRadius="0"
                Padding="16"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Период:" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <DatePicker x:Name="StartDatePicker" Width="150" SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                <DatePicker x:Name="EndDatePicker" Width="150" Margin="12,0,0,0" SelectedDateChanged="DatePicker_SelectedDateChanged"/>
                <Button Content="Продажи по дням"
                        Margin="24,0,10,0"
                        Click="SalesReportButton_Click" Cursor="Hand"/>
                <Button Content="Остатки на складе" Click="StockReportButton_Click"/>
                <Button Content="Популярные товары" Click="PopularProductsButton_Click"/>
                <Button Content="Движение товаров" Click="MovementReportButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="1"
                CornerRadius="0"
                Padding="16">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock x:Name="ReportTitleTextBlock"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Content="Печать отчета"
                            Width="140"
                            Margin="24,0,0,0"
                            Click="PrintReportButton_Click"/>
                </StackPanel>

                <DataGrid x:Name="ReportDataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

